{
  "name": "switchbox-js",
  "version": "0.3.1",
  "description": "Feature flag SDK for the browser. Zero dependencies.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "feature-flags",
    "feature-toggles",
    "switchbox",
    "browser",
    "sdk"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
